# ============================================================
# Boomzy — Environment Variables Template
# ============================================================
# Copy this file to .env for local reference only.
# Add the same values as Cloudflare Pages environment variables for production.
# NEVER commit .env to version control.

# Google Apps Script web app URL.
# This is the /exec URL from Deploy > New deployment > Web app.
APPS_SCRIPT_WEBHOOK_URL="https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec"

# Random shared secret used by Cloudflare Pages Functions and Apps Script.
# Generate with: openssl rand -hex 32
APPS_SCRIPT_SHARED_SECRET="replace-with-a-long-random-secret"

# Optional. Enables international city/region suggestions in the contact form.
# Register a free username at https://www.geonames.org/login
GEONAMES_USERNAME="your-geonames-username"
