# ============================================================
# Boomzy Ignite — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control!

# Gemini AI API Key (server-side only)
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Firebase Admin SDK (server-side)
# Get from: Firebase Console > Project Settings > Service Accounts > Generate Private Key
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# CORS origin for Express server (your frontend URL)
CORS_ORIGIN="http://localhost:3000"

# Express server port
PORT=3001

# Toggle In-Memory Mock Database (set to true to run offline without Firebase setup)
USE_MOCK_FIRESTORE="true"

# ============================================================
# Frontend (Vite) — prefix with VITE_ to expose to browser
# ============================================================
# Get from: Firebase Console > Project Settings > General > Your Apps > Web App
VITE_FIREBASE_API_KEY="your-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project-id.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
VITE_FIREBASE_APP_ID="your-app-id"
