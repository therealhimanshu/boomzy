rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // LEADS COLLECTION
    // All access is server-only via Firebase Admin SDK.
    // Public submissions go through Express API with validation.
    // ============================================================
    match /leads/{leadId} {
      allow read, write: if false;
    }

    // ============================================================
    // NEWSLETTER COLLECTION
    // All access is server-only via Firebase Admin SDK.
    // Public subscriptions go through Express API with validation.
    // ============================================================
    match /newsletter/{subId} {
      allow read, write: if false;
    }

    // ============================================================
    // ANALYTICS COLLECTION
    // All access is server-only via Firebase Admin SDK.
    // Events are tracked through the Express API.
    // ============================================================
    match /analytics/{docId} {
      allow read, write: if false;
    }

    // ============================================================
    // CATCH-ALL: Deny everything else
    // ============================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
